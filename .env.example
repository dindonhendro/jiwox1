VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# iPay88 QRIS payment
# ---------------------------------------------------------------------------
# The frontend only needs the base URL used to build the /result redirect. All
# iPay88 SECRETS live server-side as Supabase Edge Function secrets — NEVER put
# the MerchantKey in any VITE_* variable (it would ship to the browser).

# Frontend base URL (used by the ipay88-response function to redirect to /result)
VITE_PUBLIC_BASE_URL=http://localhost:5173

# Set the following as Supabase secrets (not here), e.g.:
#   supabase secrets set IPAY88_MERCHANT_CODE=... IPAY88_MERCHANT_KEY=... \
#     IPAY88_API_URL=https://sandbox.ipay88.co.id/ePayment/WebService/PaymentAPI/Checkout \
#     PUBLIC_BASE_URL=http://localhost:5173
#
#   IPAY88_MERCHANT_CODE   iPay88 merchant code (sandbox: ID02064)
#   IPAY88_MERCHANT_KEY    iPay88 merchant key  (SECRET — server only)
#   IPAY88_API_URL         Checkout WebService URL (sandbox vs production)
#   IPAY88_PAYMENT_ID      Optional QRIS PaymentId override (sandbox 78 / prod 120)
#   PUBLIC_BASE_URL        Frontend origin for the /result redirect
